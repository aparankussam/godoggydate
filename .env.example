# ─────────────────────────────────────────────────────────────
# GoDoggyDate — Environment Variables
# Copy this file to .env.local (web) or .env (mobile/root)
# NEVER commit real keys to version control.
# ─────────────────────────────────────────────────────────────

# ── Firebase ──────────────────────────────────────────────────
# Web (Next.js) — prefix NEXT_PUBLIC_ for client-side access
NEXT_PUBLIC_FIREBASE_API_KEY=firebase_placeholder
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=godoggydate-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=godoggydate-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:placeholder

# Mobile (Expo) — prefix EXPO_PUBLIC_ for client-side access
EXPO_PUBLIC_FIREBASE_API_KEY=firebase_placeholder
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=godoggydate-dev
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=godoggydate-dev.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:placeholder

# ── Stripe ────────────────────────────────────────────────────
# Web (public — safe to expose in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Mobile (public — safe to expose in app)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
EXPO_PUBLIC_PAYMENTS_API_URL=http://localhost:3000
# Optional fallback if mobile should call the main web origin directly
EXPO_PUBLIC_WEB_URL=http://localhost:3000

# Server-side only — NEVER expose to client
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ── Mapbox ────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.mapbox_placeholder
EXPO_PUBLIC_MAPBOX_TOKEN=pk.mapbox_placeholder

# ── Firebase Admin (server/functions only) ────────────────────
FIREBASE_PROJECT_ID=godoggydate-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Point to your service account JSON for local admin SDK usage:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ── Google Sign-In (Expo native + browser) ─────────────────────
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=google_expo_client_id_placeholder
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=google_web_client_id_placeholder
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=google_ios_client_id_placeholder
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=google_android_client_id_placeholder

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
EXPO_PUBLIC_EAS_PROJECT_ID=your-expo-eas-project-id
NODE_ENV=development
