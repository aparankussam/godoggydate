rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPartyToMatch(matchData) {
      return isSignedIn()
          && (
            request.auth.uid == matchData.dog1UserId ||
            request.auth.uid == matchData.dog2UserId
          );
    }

    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /dogs/{dogId} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.auth.uid == dogId;
      allow update: if isSignedIn()
                    && request.auth.uid == dogId;
      allow delete: if isSignedIn()
                    && request.auth.uid == dogId;
    }

    match /swipes/{userId}/decisions/{targetDogId} {
      allow read: if isSignedIn();

      allow create, update: if isSignedIn()
                            && request.auth.uid == userId
                            && request.resource.data.targetUserId is string
                            && request.resource.data.action in ['like', 'pass'];

      allow delete: if false;
    }

    match /matches/{matchId} {
      allow read:   if isSignedIn() && isPartyToMatch(resource.data);
      allow create: if isSignedIn();
      allow update: if isSignedIn()
                    && isPartyToMatch(resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['chatUnlocked', 'paymentId', 'lastMessage', 'lastMessageTime', 'lastMessageFromUid']);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
                    && exists(/databases/$(database)/documents/matches/$(matchId))
                    && isPartyToMatch(get(/databases/$(database)/documents/matches/$(matchId)).data);

        allow create: if isSignedIn()
                      && request.resource.data.fromUserId == request.auth.uid
                      && exists(/databases/$(database)/documents/matches/$(matchId))
                      && isPartyToMatch(get(/databases/$(database)/documents/matches/$(matchId)).data);

        allow update: if false;
        allow delete: if false;
      }
    }

    match /ratings/{ratingId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.raterId == request.auth.uid
                    && !exists(/databases/$(database)/documents/ratings/$(request.auth.uid + '_' + request.resource.data.matchId));
      allow update: if false;
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read:   if isSignedIn()
                    && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.resource.data.reporterId == request.auth.uid;
      allow read:   if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
